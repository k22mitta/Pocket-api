# Copy to .env and fill in real values. Never commit .env.

# Postgres connection string.
DATABASE_URL=postgres://user:password@localhost:5432/pocket?sslmode=disable

# Signing secret for auth JWTs. Required — the server refuses to start
# without it. Generate one with: openssl rand -base64 32
JWT_SECRET=

# Port the API listens on. Defaults to 8080 if unset.
PORT=8080

# Plaid API credentials (https://dashboard.plaid.com/team-settings/keys).
PLAID_CLIENT_ID=
PLAID_SECRET=
# One of: sandbox, development, production. Defaults to sandbox if unset.
PLAID_ENV=sandbox

# Gemini API key for the "Ask Pocket" chat feature (https://aistudio.google.com/apikey).
GEMINI_API_KEY=

# Origin(s) allowed to call the API from a browser, comma-separated for more
# than one (e.g. production + staging frontends). Defaults to "*" if unset,
# which is fine for local development but should be set to your real
# frontend origin(s) in production.
CORS_ALLOWED_ORIGIN=http://localhost:3000
